## 🔥 **Enemy Spawner (8 Arah + Pola)**

```gdscript id="u9tqgi"
@onready var enemy_scene = preload("res://Enemy.tscn")
@onready var enemies = $"../Enemies"

var directions = [
	Vector2.UP,
	Vector2.DOWN,
	Vector2.LEFT,
	Vector2.RIGHT,
	Vector2(-1,-1).normalized(),
	Vector2(1,-1).normalized(),
	Vector2(-1,1).normalized(),
	Vector2(1,1).normalized()
]

func spawn_wave():
	# pilih 2 arah random
	var dir1 = directions.pick_random()
	var dir2 = directions.pick_random()
	
	spawn_line(dir1)
	spawn_line(dir2)


func spawn_line(direction):
	for i in range(5): # koloni (5 musuh)
		var enemy = enemy_scene.instantiate()
		
		# spawn posisi dari luar arena
		enemy.global_position = get_spawn_position(direction) - direction * i * 50
		enemy.direction = direction
		
		enemies.add_child(enemy)


func get_spawn_position(direction):
	return get_viewport_rect().size / 2 + direction * 400
```

